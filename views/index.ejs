<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="bg-gradient"></div>

  <div class="container">
    <!-- Header -->
    <header class="header">
      <h1>🌐 网络质量检测</h1>
      <p>全面检测您的网络连接质量，所有测试均在您的浏览器中完成</p>
      <div class="client-badge">
        <span>✓</span>
        <span>100% 客户端检测，真实反映您的网络状况</span>
      </div>
    </header>

    <!-- Start Button -->
    <div style="text-align: center; margin-bottom: 30px;">
      <button class="btn-primary" id="checkBtn">
        <span>🚀</span>
        <span>开始检测</span>
      </button>
    </div>

    <!-- Loading -->
    <div class="loading-container" id="loading">
      <div class="loading-spinner"></div>
      <p class="loading-text" id="loadingText">正在初始化检测...</p>
      <div class="loading-progress">
        <div class="loading-progress-bar"></div>
      </div>
    </div>

    <!-- Error -->
    <div class="error-container" id="error">
      <div class="icon">⚠️</div>
      <p id="errorText"></p>
    </div>

    <!-- Results -->
    <div class="results" id="results">
      <!-- 基本信息 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">📍</div>
          <h2 class="section-title">基本信息</h2>
        </div>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">公网 IP 地址</span>
            <span class="info-value" id="ip">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">NAT 类型</span>
            <span class="info-value" id="natType">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">检测时间</span>
            <span class="info-value" id="timestamp">-</span>
          </div>
        </div>
      </div>

      <!-- 客户端测速 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">⚡</div>
          <h2 class="section-title">网络速度与延迟</h2>
        </div>
        <div class="cards-grid" id="speedtestInfo"></div>
        <!-- 速度仪表盘 -->
        <div class="charts-grid" id="speedChartsContainer" style="display: none;">
          <div class="chart-card">
            <div class="chart-title"><span class="chart-title-icon">🏎️</span>速度仪表盘</div>
            <div class="speedometer-container">
              <div class="speedometer">
                <svg class="speedometer-svg" viewBox="0 0 200 120">
                  <!-- 背景弧 -->
                  <path d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="#334155" stroke-width="12" stroke-linecap="round"/>
                  <!-- 刻度 -->
                  <g fill="none" stroke="#475569" stroke-width="1">
                    <line x1="28" y1="95" x2="35" y2="90"/>
                    <line x1="45" y1="55" x2="52" y2="62"/>
                    <line x1="100" y1="25" x2="100" y2="35"/>
                    <line x1="155" y1="55" x2="148" y2="62"/>
                    <line x1="172" y1="95" x2="165" y2="90"/>
                  </g>
                  <!-- 刻度标签 -->
                  <g fill="#94a3b8" font-size="10" text-anchor="middle" font-family="sans-serif">
                    <text x="25" y="90">0</text>
                    <text x="100" y="18">1250</text>
                    <text x="175" y="90">2500</text>
                  </g>
                  <!-- 进度弧 -->
                  <path id="speedometerArc" d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="url(#speedGradient)" stroke-width="12" stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="251.2"/>
                  <!-- 渐变定义 -->
                  <defs>
                    <linearGradient id="speedGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" style="stop-color:#10b981"/>
                      <stop offset="50%" style="stop-color:#f59e0b"/>
                      <stop offset="100%" style="stop-color:#ef4444"/>
                    </linearGradient>
                  </defs>
                  <!-- 指针 -->
                  <line id="speedometerNeedle" x1="100" y1="100" x2="100" y2="40" stroke="#a5b4fc" stroke-width="3" stroke-linecap="round"/>
                  <circle cx="100" cy="100" r="8" fill="#a5b4fc"/>
                </svg>
                <div class="speedometer-value">
                  <div class="speedometer-number" id="speedometerValue">0</div>
                  <div class="speedometer-unit">Mbps</div>
                </div>
              </div>
            </div>
          </div>
          <!-- 实时延迟波动图 -->
          <div class="chart-card" style="grid-column: span 1;">
            <div class="chart-title"><span class="chart-title-icon">📈</span>延迟波动</div>
            <div class="chart-wrapper chart-wrapper-small">
              <div id="latencyLiveChart"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- DNS 解析速度 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">🔍</div>
          <h2 class="section-title">DNS 解析速度</h2>
        </div>
        <div id="dnsInfo"></div>
        <!-- DNS 对比柱状图 -->
        <div class="chart-container" id="dnsChartContainer" style="display: none;">
          <div class="chart-title"><span class="chart-title-icon">📊</span>DNS 解析速度对比</div>
          <div class="chart-wrapper">
            <div id="dnsChart"></div>
          </div>
        </div>
      </div>

      <!-- 网站访问检测 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">🔗</div>
          <h2 class="section-title">常用网站访问检测</h2>
        </div>
        <div class="cards-grid" id="websiteInfo"></div>
      </div>

      <!-- 历史趋势 -->
      <div class="section" id="historySection" style="display: none;">
        <div class="section-header">
          <div class="section-icon">📉</div>
          <h2 class="section-title">测试历史趋势</h2>
        </div>
        <div class="history-section">
          <div class="history-header">
            <div class="history-title">📈 历史数据对比</div>
            <div class="history-actions">
              <button class="history-btn active" data-range="7">近7次</button>
              <button class="history-btn" data-range="14">近14次</button>
              <button class="history-btn" data-range="all">全部</button>
              <button class="history-btn" id="clearHistoryBtn" style="color: var(--danger);">清除历史</button>
            </div>
          </div>
          <div class="chart-wrapper">
            <div id="historyChart"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <p>所有检测均在您的浏览器中完成，数据不会上传到服务器</p>
    </footer>
  </div>

  <script src="/js/app.js" defer></script>
</body>
</html>
