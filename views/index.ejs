<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #6366f1;
      --primary-dark: #4f46e5;
      --primary-light: #a5b4fc;
      --secondary: #8b5cf6;
      --accent: #06b6d4;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --bg-main: #0f172a;
      --bg-card: #1e293b;
      --bg-card-hover: #334155;
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --border: #334155;
      --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -2px rgba(0, 0, 0, 0.2);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.3);
      --radius: 12px;
      --radius-sm: 8px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-main);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* 背景动画 */
    .bg-gradient {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: 
        radial-gradient(ellipse at 20% 20%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(6, 182, 212, 0.1) 0%, transparent 50%);
      z-index: -1;
      animation: bgMove 20s ease-in-out infinite;
    }

    @keyframes bgMove {
      0%, 100% { transform: scale(1) rotate(0deg); }
      50% { transform: scale(1.1) rotate(2deg); }
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    /* Header */
    .header {
      text-align: center;
      padding: 40px 20px 30px;
    }

    .header h1 {
      font-size: 2.5rem;
      font-weight: 700;
      background: linear-gradient(135deg, var(--primary-light) 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 10px;
      letter-spacing: -0.5px;
    }

    .header p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    /* 主按钮 */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 40px;
      font-size: 1.1rem;
      font-weight: 600;
      color: white;
      background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: var(--shadow-lg);
      position: relative;
      overflow: hidden;
    }

    .btn-primary::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s ease;
    }

    .btn-primary:hover:not(:disabled)::before {
      left: 100%;
    }

    .btn-primary:hover:not(:disabled) {
      transform: translateY(-3px);
      box-shadow: 0 20px 25px -5px rgba(99, 102, 241, 0.3);
    }

    .btn-primary:active:not(:disabled) {
      transform: translateY(-1px);
    }

    .btn-primary:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .btn-primary .icon {
      font-size: 1.3rem;
    }

    /* Loading */
    .loading-container {
      display: none;
      text-align: center;
      padding: 30px;
    }

    .loading-container.active {
      display: block;
    }

    .loading-spinner {
      width: 50px;
      height: 50px;
      border: 3px solid var(--border);
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 20px;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .loading-text {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .loading-progress {
      margin-top: 20px;
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
      max-width: 300px;
      margin-left: auto;
      margin-right: auto;
    }

    .loading-progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--primary), var(--accent));
      border-radius: 2px;
      animation: progress 2s ease-in-out infinite;
    }

    @keyframes progress {
      0% { width: 0%; margin-left: 0; }
      50% { width: 70%; margin-left: 15%; }
      100% { width: 0%; margin-left: 100%; }
    }

    /* Error */
    .error-container {
      display: none;
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.05) 100%);
      border: 1px solid rgba(239, 68, 68, 0.3);
      border-radius: var(--radius);
      padding: 20px;
      margin: 20px 0;
      text-align: center;
    }

    .error-container.active {
      display: block;
    }

    .error-container .icon {
      font-size: 2rem;
      margin-bottom: 10px;
    }

    .error-container p {
      color: #fca5a5;
    }

    /* Results */
    .results {
      display: none;
      animation: fadeInUp 0.6s ease;
    }

    .results.active {
      display: block;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Section */
    .section {
      background: var(--bg-card);
      border-radius: var(--radius);
      padding: 24px;
      margin-bottom: 20px;
      border: 1px solid var(--border);
      transition: all 0.3s ease;
    }

    .section:hover {
      border-color: var(--primary);
      box-shadow: 0 0 20px rgba(99, 102, 241, 0.1);
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid var(--border);
    }

    .section-icon {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
      border-radius: var(--radius-sm);
      font-size: 1.2rem;
    }

    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    /* Info Grid */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .info-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .info-label {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .info-value {
      font-size: 1rem;
      color: var(--text-primary);
      font-weight: 500;
    }

    .info-value code {
      background: var(--bg-main);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.9rem;
      color: var(--accent);
    }

    /* Cards Grid */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
    }

    .card {
      background: var(--bg-main);
      border-radius: var(--radius-sm);
      padding: 18px;
      border: 1px solid var(--border);
      transition: all 0.3s ease;
    }

    .card:hover {
      background: var(--bg-card-hover);
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 15px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .card-icon {
      font-size: 1.4rem;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .card-content p {
      margin-bottom: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .card-content .label {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .card-content .value {
      font-weight: 500;
    }

    /* Latency Colors */
    .latency-good { color: var(--success); }
    .latency-medium { color: var(--warning); }
    .latency-bad { color: var(--danger); }
    .status-good { color: var(--success); }
    .status-bad { color: var(--danger); }

    /* Speed Gauge */
    .speed-gauge {
      text-align: center;
      padding: 20px 0;
    }

    .speed-value {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 5px;
    }

    .speed-unit {
      font-size: 1rem;
      color: var(--text-muted);
    }

    .speed-bar {
      height: 8px;
      background: var(--border);
      border-radius: 4px;
      margin-top: 15px;
      overflow: hidden;
    }

    .speed-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 1s ease;
    }

    .speed-bar-fill.good {
      background: linear-gradient(90deg, var(--success), #34d399);
    }

    .speed-bar-fill.medium {
      background: linear-gradient(90deg, var(--warning), #fbbf24);
    }

    .speed-bar-fill.bad {
      background: linear-gradient(90deg, var(--danger), #f87171);
    }

    /* AS Path */
    .as-path {
      background: var(--bg-card);
      padding: 10px 14px;
      border-radius: var(--radius-sm);
      font-family: 'Monaco', 'Consolas', monospace;
      font-size: 0.85rem;
      color: var(--accent);
      margin: 8px 0;
      word-break: break-all;
      border-left: 3px solid var(--primary);
    }

    /* Details Toggle */
    .details-toggle {
      margin-top: 12px;
    }

    .details-toggle summary {
      cursor: pointer;
      color: var(--primary);
      font-size: 0.9rem;
      padding: 8px 0;
      transition: color 0.2s ease;
    }

    .details-toggle summary:hover {
      color: var(--primary-light);
    }

    .details-toggle[open] summary {
      margin-bottom: 10px;
    }

    .details-content {
      padding: 10px;
      background: var(--bg-card);
      border-radius: var(--radius-sm);
    }

    .details-content p {
      margin: 6px 0;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    /* Website Card */
    .website-card {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 15px;
    }

    .website-icon {
      width: 45px;
      height: 45px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-card);
      border-radius: var(--radius-sm);
      font-size: 1.5rem;
    }

    .website-info {
      flex: 1;
    }

    .website-name {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .website-url {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .website-status {
      text-align: right;
    }

    .website-status .status {
      font-weight: 600;
      margin-bottom: 4px;
    }

    .website-status .delay {
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 30px 20px;
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .footer a {
      color: var(--primary-light);
      text-decoration: none;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .header h1 {
        font-size: 1.8rem;
      }

      .header p {
        font-size: 1rem;
      }

      .btn-primary {
        padding: 14px 30px;
        font-size: 1rem;
      }

      .section {
        padding: 18px;
      }

      .cards-grid {
        grid-template-columns: 1fr;
      }

      .info-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Animations */
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    .pulse {
      animation: pulse 2s ease-in-out infinite;
    }

    /* Stagger animations for cards */
    .cards-grid .card:nth-child(1) { animation-delay: 0.1s; }
    .cards-grid .card:nth-child(2) { animation-delay: 0.2s; }
    .cards-grid .card:nth-child(3) { animation-delay: 0.3s; }

    @keyframes cardFadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .card-animated {
      animation: cardFadeIn 0.5s ease forwards;
      opacity: 0;
    }
  </style>
</head>
<body>
  <div class="bg-gradient"></div>
  
  <div class="container">
    <!-- Header -->
    <header class="header">
      <h1>🌐 网络质量检测</h1>
      <p>全面检测您的网络连接质量，包括延迟、速度、路由等关键指标</p>
    </header>

    <!-- Start Button -->
    <div style="text-align: center; margin-bottom: 30px;">
      <button class="btn-primary" id="checkBtn">
        <span class="icon">🚀</span>
        <span>开始检测</span>
      </button>
    </div>

    <!-- Loading -->
    <div class="loading-container" id="loading">
      <div class="loading-spinner"></div>
      <p class="loading-text" id="loadingText">正在初始化检测...</p>
      <div class="loading-progress">
        <div class="loading-progress-bar"></div>
      </div>
    </div>

    <!-- Error -->
    <div class="error-container" id="error">
      <div class="icon">⚠️</div>
      <p id="errorText"></p>
    </div>

    <!-- Results -->
    <div class="results" id="results">
      <!-- 基本信息 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">📍</div>
          <h2 class="section-title">基本信息</h2>
        </div>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">IP 地址</span>
            <span class="info-value" id="ip">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">检测时间</span>
            <span class="info-value" id="timestamp">-</span>
          </div>
        </div>
      </div>

      <!-- 本地状态 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">💻</div>
          <h2 class="section-title">本地状态</h2>
        </div>
        <div class="info-grid" id="localInfo"></div>
      </div>

      <!-- 客户端测速 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">⚡</div>
          <h2 class="section-title">客户端测速</h2>
        </div>
        <div class="cards-grid" id="speedtestInfo"></div>
      </div>

      <!-- 三网延迟 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">📡</div>
          <h2 class="section-title">三网延迟</h2>
        </div>
        <div class="cards-grid" id="delayInfo"></div>
      </div>

      <!-- 三网回程路由 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">🔀</div>
          <h2 class="section-title">三网回程路由</h2>
        </div>
        <div class="cards-grid" id="routeInfo"></div>
      </div>

      <!-- 国际互连 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">🌍</div>
          <h2 class="section-title">国际互连</h2>
        </div>
        <div class="cards-grid" id="globalInfo"></div>
      </div>

      <!-- 网站访问检测 -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon">🔗</div>
          <h2 class="section-title">常用网站访问检测</h2>
        </div>
        <div class="cards-grid" id="websiteInfo"></div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <p>数据仅供参考，实际网络状况可能因多种因素而异</p>
    </footer>
  </div>

  <script>
    // 工具函数
    function getLatencyClass(latency) {
      const val = parseFloat(latency);
      if (isNaN(val)) return '';
      if (val < 50) return 'latency-good';
      if (val < 100) return 'latency-medium';
      return 'latency-bad';
    }

    function getSpeedClass(speed) {
      const val = parseFloat(speed);
      if (isNaN(val)) return 'bad';
      if (val > 50) return 'good';
      if (val > 20) return 'medium';
      return 'bad';
    }

    function renderLatency(data) {
      if (!data) return '<span class="latency-bad">超时</span>';
      const cls = getLatencyClass(data.avg);
      return `<span class="${cls}">${data.avg}ms</span> <small style="color: var(--text-muted)">(min: ${data.min}ms, max: ${data.max}ms)</small>`;
    }

    // 客户端速度测试
    async function testDownloadSpeed() {
      const size = 10;
      const startTime = Date.now();
      try {
        const response = await fetch(`/speedtest/${size}`, { method: 'GET', cache: 'no-cache' });
        if (!response.ok) throw new Error('测速失败');
        const blob = await response.blob();
        const endTime = Date.now();
        const duration = (endTime - startTime) / 1000;
        const speed = (size * 8) / duration;
        return speed.toFixed(2);
      } catch (error) {
        return '未知';
      }
    }

    async function testPing() {
      const startTime = Date.now();
      try {
        await fetch('/health');
        const endTime = Date.now();
        return (endTime - startTime).toFixed(2);
      } catch (error) {
        return '未知';
      }
    }

    async function getClientIP() {
      try {
        const response = await fetch('https://api.ipify.org?format=json');
        const data = await response.json();
        return data.ip;
      } catch (error) {
        return '未知';
      }
    }

    // NAT 类型检测（使用 WebRTC STUN）
    async function detectNATType() {
      const stunServers = [
        'stun:stun.l.google.com:19302',
        'stun:stun1.l.google.com:19302',
        'stun:stun2.l.google.com:19302'
      ];

      return new Promise((resolve) => {
        let natType = '检测失败';
        let localIPs = new Set();
        let publicIPs = new Set();

        try {
          const pc = new RTCPeerConnection({
            iceServers: [{ urls: stunServers }]
          });

          pc.createDataChannel('');

          pc.onicecandidate = (event) => {
            if (event.candidate) {
              const candidate = event.candidate.candidate;
              
              // 提取本地 IP
              const localMatch = candidate.match(/(\d+\.\d+\.\d+\.\d+)/g);
              if (localMatch) {
                localIPs.add(localMatch[0]);
              }

              // 判断候选类型
              if (candidate.includes('typ host')) {
                // 本地主机地址
              } else if (candidate.includes('typ srflx')) {
                // 服务器反射地址 - 表示有 NAT
                const ipMatch = candidate.match(/(\d+\.\d+\.\d+\.\d+)/g);
                if (ipMatch && ipMatch.length >= 2) {
                  publicIPs.add(ipMatch[ipMatch.length - 1]);
                }
              } else if (candidate.includes('typ prflx')) {
                // 对等反射地址
              } else if (candidate.includes('typ relay')) {
                // 中继地址
              }
            }
          };

          pc.onicegatheringstatechange = () => {
            if (pc.iceGatheringState === 'complete') {
              // 分析 NAT 类型
              const candidates = pc.localDescription ? pc.localDescription.sdp : '';
              
              if (candidates.includes('typ relay')) {
                natType = '对称型 NAT (Symmetric)';
              } else if (candidates.includes('typ prflx')) {
                natType = '端口受限锥形 NAT (Port Restricted)';
              } else if (candidates.includes('typ srflx')) {
                // 检查是否多个 srflx 候选
                const srflxMatches = candidates.match(/typ srflx/g) || [];
                if (srflxMatches.length > 1) {
                  natType = '受限锥形 NAT (Restricted)';
                } else {
                  natType = '完全锥形 NAT (Full Cone)';
                }
              } else {
                natType = '无 NAT (直接连接)';
              }

              pc.close();
              resolve(natType);
            }
          };

          pc.createOffer()
            .then(offer => pc.setLocalDescription(offer))
            .catch(() => {
              pc.close();
              resolve('检测失败');
            });

          // 超时处理
          setTimeout(() => {
            if (pc.iceGatheringState !== 'complete') {
              pc.close();
              // 如果有 srflx 候选，说明有 NAT
              if (publicIPs.size > 0) {
                resolve('有 NAT (类型未知)');
              } else if (localIPs.size > 0) {
                resolve('无 NAT 或检测超时');
              } else {
                resolve('检测超时');
              }
            }
          }, 5000);

        } catch (e) {
          resolve('不支持 WebRTC');
        }
      });
    }

    // 主检测流程
    document.getElementById('checkBtn').addEventListener('click', async function() {
      const btn = this;
      const loading = document.getElementById('loading');
      const loadingText = document.getElementById('loadingText');
      const error = document.getElementById('error');
      const results = document.getElementById('results');

      btn.disabled = true;
      loading.classList.add('active');
      error.classList.remove('active');
      results.classList.remove('active');

      const steps = [
        '正在获取客户端 IP 地址...',
        '正在检测 NAT 类型...',
        '正在测试客户端下载速度...',
        '正在测试客户端延迟...',
        '正在检测三网延迟（可能需要较长时间）...',
        '正在检测网站访问情况...'
      ];

      try {
        // Step 1: 获取 IP
        loadingText.textContent = steps[0];
        const clientIP = await getClientIP();

        // Step 1.5: 检测 NAT 类型
        loadingText.textContent = steps[1];
        const natType = await detectNATType();

        // Step 2: 测试速度
        loadingText.textContent = steps[2];
        const downloadSpeed = await testDownloadSpeed();

        // Step 3: 测试延迟
        loadingText.textContent = steps[3];
        const ping = await testPing();

        // Step 4: 获取服务器端信息
        loadingText.textContent = steps[4];
        const response = await fetch('/check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ clientIP })
        });

        if (!response.ok) throw new Error('检测请求失败');
        const data = await response.json();

        // 渲染结果
        renderResults(data, downloadSpeed, ping, natType);

        // Step 5: 网站检测
        loadingText.textContent = steps[5];
        await renderWebsites();

        results.classList.add('active');

      } catch (err) {
        document.getElementById('errorText').textContent = '检测过程中发生错误: ' + err.message;
        error.classList.add('active');
      } finally {
        btn.disabled = false;
        loading.classList.remove('active');
      }
    });

    function renderResults(data, downloadSpeed, ping, natType) {
      // 基本信息
      document.getElementById('ip').textContent = data.ip || '未知';
      document.getElementById('timestamp').textContent = new Date(data.timestamp).toLocaleString();

      // 本地状态
      const localInfo = document.getElementById('localInfo');
      localInfo.innerHTML = `
        <div class="info-item"><span class="info-label">NAT 类型</span><span class="info-value">${natType || '检测失败'}</span></div>
        <div class="info-item"><span class="info-label">TCP 拥塞控制</span><span class="info-value"><code>${data.local.tcpCongestion || '未知'}</code></span></div>
        <div class="info-item"><span class="info-label">队列调度</span><span class="info-value"><code>${data.local.queueDiscipline || '未知'}</code></span></div>
        <div class="info-item"><span class="info-label">TCP 接收缓冲区</span><span class="info-value"><code>${data.local.tcpReceiveBuffer || '未知'}</code></span></div>
        <div class="info-item"><span class="info-label">TCP 发送缓冲区</span><span class="info-value"><code>${data.local.tcpSendBuffer || '未知'}</code></span></div>
        <div class="info-item"><span class="info-label">默认路由</span><span class="info-value"><code>${data.local.defaultRoute || '未知'}</code></span></div>
        <div class="info-item"><span class="info-label">DNS 服务器</span><span class="info-value"><code>${data.local.dnsServers || '未知'}</code></span></div>
        <div class="info-item"><span class="info-label">网络接口</span><span class="info-value">${data.local.interfaces || '未知'}</span></div>
      `;

      // 客户端测速
      const speedClass = getSpeedClass(downloadSpeed);
      const speedVal = parseFloat(downloadSpeed) || 0;
      const speedtestInfo = document.getElementById('speedtestInfo');
      speedtestInfo.innerHTML = `
        <div class="card card-animated">
          <div class="speed-gauge">
            <div class="speed-value ${speedClass === 'good' ? 'latency-good' : speedClass === 'medium' ? 'latency-medium' : 'latency-bad'}">${downloadSpeed}</div>
            <div class="speed-unit">Mbps 下载速度</div>
            <div class="speed-bar">
              <div class="speed-bar-fill ${speedClass}" style="width: ${Math.min(100, speedVal)}%"></div>
            </div>
          </div>
        </div>
        <div class="card card-animated">
          <div class="speed-gauge">
            <div class="speed-value ${getLatencyClass(ping)}">${ping}</div>
            <div class="speed-unit">ms 客户端延迟</div>
            <div class="speed-bar">
              <div class="speed-bar-fill ${parseFloat(ping) < 50 ? 'good' : parseFloat(ping) < 100 ? 'medium' : 'bad'}" style="width: ${Math.min(100, 200 - parseFloat(ping))}%"></div>
            </div>
          </div>
        </div>
      `;

      // 三网延迟
      const isps = [
        { key: 'telecom', name: '中国电信', icon: '📱' },
        { key: 'unicom', name: '中国联通', icon: '📶' },
        { key: 'mobile', name: '中国移动', icon: '📲' }
      ];

      const delayInfo = document.getElementById('delayInfo');
      delayInfo.innerHTML = isps.map((isp, idx) => `
        <div class="card card-animated" style="animation-delay: ${idx * 0.1}s">
          <div class="card-header">
            <span class="card-icon">${isp.icon}</span>
            <span class="card-title">${isp.name}</span>
          </div>
          <div class="card-content">
            <p><span class="label">北京</span><span class="value">${renderLatency(data.delay[isp.key]?.beijing)}</span></p>
            <p><span class="label">上海</span><span class="value">${renderLatency(data.delay[isp.key]?.shanghai)}</span></p>
            <p><span class="label">广州</span><span class="value">${renderLatency(data.delay[isp.key]?.guangzhou)}</span></p>
          </div>
        </div>
      `).join('');

      // 三网回程路由
      const routeInfo = document.getElementById('routeInfo');
      routeInfo.innerHTML = isps.map((isp, idx) => {
        const route = data.route[isp.key];
        return `
          <div class="card card-animated" style="animation-delay: ${idx * 0.1}s">
            <div class="card-header">
              <span class="card-icon">${isp.icon}</span>
              <span class="card-title">${isp.name}</span>
            </div>
            <div class="card-content">
              <p><span class="label">北京</span></p>
              <div class="as-path">${route?.beijing?.asPath || '无法获取'}</div>
              ${route?.beijing?.avgLatency ? `<p><span class="label">延迟</span><span class="value ${getLatencyClass(route.beijing.avgLatency)}">${route.beijing.avgLatency}ms</span></p>` : ''}
              
              <p style="margin-top:12px"><span class="label">上海</span></p>
              <div class="as-path">${route?.shanghai?.asPath || '无法获取'}</div>
              ${route?.shanghai?.avgLatency ? `<p><span class="label">延迟</span><span class="value ${getLatencyClass(route.shanghai.avgLatency)}">${route.shanghai.avgLatency}ms</span></p>` : ''}
              
              <p style="margin-top:12px"><span class="label">广州</span></p>
              <div class="as-path">${route?.guangzhou?.asPath || '无法获取'}</div>
              ${route?.guangzhou?.avgLatency ? `<p><span class="label">延迟</span><span class="value ${getLatencyClass(route.guangzhou.avgLatency)}">${route.guangzhou.avgLatency}ms</span></p>` : ''}
            </div>
          </div>
        `;
      }).join('');

      // 国际互连
      const regions = [
        { key: 'northAmerica', name: '北美', icon: '🇺🇸' },
        { key: 'europe', name: '欧洲', icon: '🇪🇺' },
        { key: 'asia', name: '亚洲', icon: '🌏' }
      ];

      const globalInfo = document.getElementById('globalInfo');
      globalInfo.innerHTML = regions.map((region, idx) => {
        const info = data.global[region.key];
        return `
          <div class="card card-animated" style="animation-delay: ${idx * 0.1}s">
            <div class="card-header">
              <span class="card-icon">${region.icon}</span>
              <span class="card-title">${region.name}</span>
            </div>
            <div class="card-content">
              <p><span class="label">平均延迟</span><span class="value ${info?.avgLatency ? getLatencyClass(info.avgLatency) : 'latency-bad'}">${info?.avgLatency ? info.avgLatency + 'ms' : '超时'}</span></p>
              ${info?.minLatency && info?.maxLatency ? `<p><span class="label">延迟范围</span><span class="value">${info.minLatency}ms - ${info.maxLatency}ms</span></p>` : ''}
              <p><span class="label">可达节点</span><span class="value">${info?.reachable || 0} / ${info?.total || 0}</span></p>
              ${info?.nodes && info.nodes.length > 0 ? `
                <details class="details-toggle">
                  <summary>查看详细节点</summary>
                  <div class="details-content">
                    ${info.nodes.map(node => `<p>${node.name}: <span class="${getLatencyClass(node.avg)}">${node.avg.toFixed(1)}ms</span></p>`).join('')}
                  </div>
                </details>
              ` : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    async function renderWebsites() {
      const websiteInfo = document.getElementById('websiteInfo');
      try {
        const response = await fetch('/test-websites');
        const websites = await response.json();

        websiteInfo.innerHTML = websites.map((site, idx) => {
          const statusClass = site.status === '可访问' ? 'status-good' : 'status-bad';
          const typeIcon = site.type === '国内' ? '🇨🇳' : '🌍';
          const delayValue = site.delay === '超时' ? null : parseFloat(site.delay);

          return `
            <div class="card card-animated" style="animation-delay: ${idx * 0.05}s">
              <div class="website-card">
                <div class="website-icon">${typeIcon}</div>
                <div class="website-info">
                  <div class="website-name">${site.name}</div>
                  <div class="website-url">${site.url}</div>
                </div>
                <div class="website-status">
                  <div class="status ${statusClass}">${site.status}</div>
                  <div class="delay ${delayValue ? getLatencyClass(delayValue) : ''}">${site.delay}${delayValue ? 'ms' : ''}</div>
                </div>
              </div>
            </div>
          `;
        }).join('');
      } catch (err) {
        websiteInfo.innerHTML = '<div class="card"><p style="text-align:center;color:var(--text-muted)">网站访问检测失败</p></div>';
      }
    }
  </script>
</body>
</html>
