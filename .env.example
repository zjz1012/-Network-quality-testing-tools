# ==================== 服务器配置 ====================
PORT=5000
NODE_ENV=development

# ==================== 速率限制配置 ====================
RATE_LIMIT_WINDOW=60000        # 速率限制窗口（毫秒）
RATE_LIMIT_MAX=30             # 每分钟最大请求数
SPEEDTEST_RATE_LIMIT=5        # 测速接口每分钟最大请求数

# ==================== 日志配置 ====================
LOG_DIR=./logs                # 日志目录
